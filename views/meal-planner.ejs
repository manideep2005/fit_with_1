<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AI Meal Planner - Fit-With-AI</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --primary: #6C63FF;
            --secondary: #4D44DB;
            --accent: #FF6584;
            --light: #F8F9FA;
            --dark: #343A40;
            --success: #28A745;
            --warning: #FFC107;
            --danger: #DC3545;
            --gray: #6C757D;
            --light-gray: #E9ECEF;
        }
        
        body {
            font-family: 'Poppins', sans-serif;
            background-color: #F5F7FA;
            color: var(--dark);
            margin: 0;
            padding: 0;
        }
        
        .dashboard-container {
            display: flex;
            min-height: 100vh;
        }
        
        .sidebar {
            width: 250px;
            background: white;
            box-shadow: 2px 0 10px rgba(0,0,0,0.1);
            padding: 2rem 1rem;
        }
        
        .sidebar-header {
            display: flex;
            align-items: center;
            margin-bottom: 2rem;
            padding: 0 1rem;
        }
        
        .user-name {
            font-weight: 600;
            margin: 0;
        }
        
        .user-plan {
            font-size: 0.8rem;
            color: var(--primary);
            background: rgba(108, 99, 255, 0.1);
            padding: 2px 8px;
            border-radius: 20px;
            margin-top: 5px;
        }
        
        .nav-menu {
            list-style: none;
            padding: 0;
            margin: 0;
        }
        
        .nav-item {
            margin-bottom: 5px;
        }
        
        .nav-link {
            display: flex;
            align-items: center;
            padding: 12px 1rem;
            color: var(--gray);
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
        }
        
        .nav-link:hover, .nav-link.active {
            background: rgba(108, 99, 255, 0.1);
            color: var(--primary);
        }
        
        .nav-link i {
            margin-right: 10px;
            font-size: 1.2rem;
        }
        
        .logout-section {
            margin-top: 2rem;
            padding-top: 1rem;
            border-top: 1px solid var(--light-gray);
        }
        
        .logout-link {
            display: flex;
            align-items: center;
            padding: 12px 1rem;
            color: var(--danger);
            text-decoration: none;
            border-radius: 8px;
            transition: all 0.3s ease;
            font-weight: 500;
        }
        
        .logout-link:hover {
            background: rgba(220, 53, 69, 0.1);
        }
        
        .logout-link i {
            margin-right: 10px;
            font-size: 1.2rem;
        }
        
        .main-content {
            flex: 1;
            padding: 2rem;
        }
        
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
        
        .page-title {
            font-size: 1.8rem;
            font-weight: 600;
            color: var(--dark);
        }
        
        .ai-meal-planner {
            display: grid;
            grid-template-columns: 2fr 1fr;
            gap: 2rem;
        }
        
        .main-panel {
            background: white;
            border-radius: 12px;
            padding: 2rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }
        
        .daily-goals {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border-radius: 12px;
            padding: 2rem;
            margin-bottom: 2rem;
        }
        
        .goals-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-top: 1rem;
        }
        
        .goal-card {
            background: rgba(255,255,255,0.1);
            border-radius: 8px;
            padding: 1rem;
            backdrop-filter: blur(10px);
        }
        
        .goal-title {
            font-size: 0.9rem;
            opacity: 0.9;
            margin-bottom: 0.5rem;
        }
        
        .goal-progress {
            font-size: 1.5rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }
        
        .progress-bar {
            height: 6px;
            background: rgba(255,255,255,0.2);
            border-radius: 3px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 100%;
            background: white;
            border-radius: 3px;
            transition: width 0.5s ease;
        }
        
        .meal-suggestions {
            margin-top: 2rem;
        }
        
        .suggestion-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 1rem;
        }
        
        .suggestion-title {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--dark);
        }
        
        .filters-container {
            display: flex;
            flex-wrap: wrap;
            gap: 1rem;
            align-items: center;
        }
        
        .regional-selector {
            padding: 8px 16px;
            border: 1px solid var(--light-gray);
            border-radius: 8px;
            background: white;
            font-family: inherit;
        }
        
        .dietary-filters {
            display: flex;
            gap: 0.5rem;
        }
        
        .filter-btn {
            padding: 6px 12px;
            border: 1px solid var(--light-gray);
            border-radius: 20px;
            background: white;
            font-size: 0.85rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .filter-btn.active {
            background: var(--primary);
            color: white;
            border-color: var(--primary);
        }
        
        .filter-btn:hover {
            background: var(--light);
        }
        
        .spice-level, .cooking-time {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            font-size: 0.9rem;
        }
        
        .spice-level select, .cooking-time select {
            padding: 4px 8px;
            border: 1px solid var(--light-gray);
            border-radius: 6px;
            font-size: 0.85rem;
        }
        
        .meal-category {
            margin-bottom: 2rem;
        }
        
        .category-header {
            display: flex;
            align-items: center;
            margin-bottom: 1rem;
            padding: 1rem;
            background: var(--light);
            border-radius: 8px;
        }
        
        .category-icon {
            width: 40px;
            height: 40px;
            border-radius: 8px;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            margin-right: 12px;
        }
        
        .category-name {
            font-weight: 600;
            font-size: 1.1rem;
        }
        
        .category-status {
            margin-left: auto;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.8rem;
            font-weight: 500;
        }
        
        .status-pending {
            background: rgba(255, 193, 7, 0.1);
            color: var(--warning);
        }
        
        .status-completed {
            background: rgba(40, 167, 69, 0.1);
            color: var(--success);
        }
        
        .meal-suggestion-card {
            background: white;
            border: 2px solid var(--light-gray);
            border-radius: 12px;
            padding: 1.5rem;
            margin-bottom: 1rem;
            transition: all 0.3s ease;
        }
        
        .meal-suggestion-card:hover {
            border-color: var(--primary);
            box-shadow: 0 4px 12px rgba(108, 99, 255, 0.1);
        }
        
        .meal-info {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1rem;
        }
        
        .meal-details h4 {
            margin: 0 0 0.5rem 0;
            color: var(--dark);
            font-weight: 600;
        }
        
        .meal-meta {
            display: flex;
            gap: 1rem;
            font-size: 0.9rem;
            color: var(--gray);
        }
        
        .meal-actions {
            display: flex;
            gap: 0.5rem;
        }
        
        .btn {
            padding: 8px 16px;
            border: none;
            border-radius: 8px;
            font-family: inherit;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
        }
        
        .btn-accept {
            background: var(--success);
            color: white;
        }
        
        .btn-reject {
            background: var(--light-gray);
            color: var(--gray);
        }
        
        .btn-accept:hover {
            background: #218838;
            transform: translateY(-1px);
        }
        
        .btn-reject:hover {
            background: var(--gray);
            color: white;
        }
        
        .btn-favorite {
            background: white;
            color: var(--accent);
            border: 1px solid var(--accent);
            padding: 8px 12px;
        }
        
        .btn-favorite.active {
            background: var(--accent);
            color: white;
        }
        
        .btn-favorite:hover {
            background: var(--accent);
            color: white;
        }
        
        .btn-share {
            background: var(--light-gray);
            color: var(--primary);
        }
        
        .btn-share:hover {
            background: var(--primary);
            color: white;
        }
        
        .meal-meta {
            display: flex;
            gap: 1rem;
            font-size: 0.9rem;
            color: var(--gray);
            flex-wrap: wrap;
        }
        
        .nutrition-chart {
            width: 60px;
            height: 60px;
            margin-left: 1rem;
        }
        
        .side-panel {
            display: flex;
            flex-direction: column;
            gap: 1.5rem;
        }
        
        .panel-card {
            background: white;
            border-radius: 12px;
            padding: 1.5rem;
            box-shadow: 0 4px 20px rgba(0,0,0,0.05);
        }
        
        .panel-title {
            font-weight: 600;
            margin-bottom: 1rem;
            color: var(--dark);
        }
        
        .meal-plan-summary {
            max-height: 400px;
            overflow-y: auto;
        }
        
        .summary-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0.75rem 0;
            border-bottom: 1px solid var(--light-gray);
        }
        
        .summary-item:last-child {
            border-bottom: none;
        }
        
        .summary-meal {
            font-weight: 500;
        }
        
        .summary-calories {
            color: var(--primary);
            font-weight: 600;
        }
        
        .total-summary {
            background: var(--light);
            border-radius: 8px;
            padding: 1rem;
            margin-top: 1rem;
            text-align: center;
        }
        
        .total-calories {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--primary);
        }
        
        .floating-ai-btn {
            position: fixed;
            bottom: 30px;
            right: 30px;
            width: 60px;
            height: 60px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            border: none;
            font-size: 1.5rem;
            cursor: pointer;
            box-shadow: 0 4px 20px rgba(108, 99, 255, 0.3);
            transition: all 0.3s ease;
        }
        
        .floating-ai-btn:hover {
            transform: scale(1.1);
        }
        
        .toast {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 15px 20px;
            border-radius: 8px;
            color: white;
            z-index: 2000;
            font-weight: 500;
        }
        
        .toast-success { background: var(--success); }
        .toast-error { background: var(--danger); }
        .toast-info { background: var(--primary); }
        
        @media (max-width: 768px) {
            .dashboard-container {
                flex-direction: column;
            }
            
            .sidebar {
                width: 100%;
                padding: 1rem;
            }
            
            .main-content {
                padding: 1rem;
            }
            
            .ai-meal-planner {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="dashboard-container">
        <!-- Sidebar -->
        <div class="sidebar">
            <div class="sidebar-header">
                <div>
                    <h3 class="user-name"><%= user.fullName %></h3>
                    <span class="user-plan">Premium Plan</span>
                </div>
            </div>
            
            <ul class="nav-menu">
                <li class="nav-item"><a href="/dashboard" class="nav-link"><i class="fas fa-home"></i> Dashboard</a></li>
                <li class="nav-item"><a href="/workouts" class="nav-link"><i class="fas fa-dumbbell"></i> Workouts</a></li>
                <li class="nav-item"><a href="/progress" class="nav-link"><i class="fas fa-chart-line"></i> Progress</a></li>
                <li class="nav-item"><a href="/nutrition" class="nav-link"><i class="fas fa-utensils"></i> Nutrition</a></li>
                <li class="nav-item"><a href="/meal-planner" class="nav-link active"><i class="fas fa-calendar-check"></i> Meal Planner</a></li>
                <li class="nav-item"><a href="/challenges" class="nav-link"><i class="fas fa-trophy"></i> Challenges</a></li>
                <li class="nav-item"><a href="/health" class="nav-link"><i class="fas fa-heartbeat"></i> Health Metrics</a></li>
                <li class="nav-item"><a href="/biometrics" class="nav-link"><i class="fas fa-chart-bar"></i> Biometrics</a></li>
                <li class="nav-item"><a href="/schedule" class="nav-link"><i class="fas fa-calendar-alt"></i> Schedule</a></li>
                <li class="nav-item"><a href="/community" class="nav-link"><i class="fas fa-users"></i> Community</a></li>
                <li class="nav-item"><a href="/ai-coach" class="nav-link"><i class="fas fa-robot"></i> AI Coach</a></li>
                <li class="nav-item"><a href="/chat" class="nav-link"><i class="fas fa-comments"></i> Chat</a></li>
                <li class="nav-item"><a href="/settings" class="nav-link"><i class="fas fa-cog"></i> Settings</a></li>
            </ul>
            
            <div class="logout-section">
                <a href="/logout" class="logout-link">
                    <i class="fas fa-sign-out-alt"></i> Logout
                </a>
            </div>
        </div>
        
        <!-- Main Content -->
        <div class="main-content">
            <div class="page-header">
                <h1 class="page-title">AI Meal Planner</h1>
                <div>
                    <button class="btn btn-accept" onclick="startAIMealPlanning()">
                        <i class="fas fa-magic"></i> Start AI Planning
                    </button>
                </div>
            </div>
            
            <!-- Daily Goals -->
            <div class="daily-goals">
                <h2 style="margin: 0 0 1rem 0;">Today's Goals</h2>
                <div class="goals-grid">
                    <div class="goal-card">
                        <div class="goal-title">Calories</div>
                        <div class="goal-progress" id="calorieProgress">650 / 2000</div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="calorieBar" style="width: 32.5%"></div>
                        </div>
                    </div>
                    <div class="goal-card">
                        <div class="goal-title">Water</div>
                        <div class="goal-progress" id="waterProgress">1.2L / 3L</div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="waterBar" style="width: 40%"></div>
                        </div>
                    </div>
                    <div class="goal-card">
                        <div class="goal-title">Protein</div>
                        <div class="goal-progress" id="proteinProgress">45g / 120g</div>
                        <div class="progress-bar">
                            <div class="progress-fill" id="proteinBar" style="width: 37.5%"></div>
                        </div>
                    </div>
                </div>
            </div>
            
            <div class="ai-meal-planner">
                <!-- Main Panel -->
                <div class="main-panel">
                    <div class="meal-suggestions">
                        <div class="suggestion-header">
                            <h3 class="suggestion-title">AI Meal Suggestions</h3>
                            <div class="filters-container">
                                <select class="regional-selector" id="regionalPreference" onchange="updateRegionalPreference()">
                                    <option value="north">North Indian</option>
                                    <option value="south">South Indian</option>
                                    <option value="east">East Indian</option>
                                    <option value="west">West Indian</option>
                                </select>
                                
                                <div class="dietary-filters">
                                    <button class="filter-btn active" id="allFilter" onclick="setDietaryFilter('all')">All</button>
                                    <button class="filter-btn" id="vegFilter" onclick="setDietaryFilter('veg')">🥬 Veg</button>
                                    <button class="filter-btn" id="nonvegFilter" onclick="setDietaryFilter('nonveg')">🍗 Non-Veg</button>
                                    <button class="filter-btn" id="veganFilter" onclick="setDietaryFilter('vegan')">🌱 Vegan</button>
                                </div>
                                
                                <div class="spice-level">
                                    <label>🌶️ Spice:</label>
                                    <select id="spiceLevel" onchange="updateSpiceLevel()">
                                        <option value="mild">Mild</option>
                                        <option value="medium" selected>Medium</option>
                                        <option value="spicy">Spicy</option>
                                    </select>
                                </div>
                                
                                <div class="cooking-time">
                                    <label>⏱️ Time:</label>
                                    <select id="cookingTime" onchange="updateCookingTime()">
                                        <option value="all">Any Time</option>
                                        <option value="quick">Quick (15min)</option>
                                        <option value="medium">Medium (30min)</option>
                                        <option value="long">Long (1hr+)</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        
                        <!-- Breakfast -->
                        <div class="meal-category" id="breakfastCategory">
                            <div class="category-header">
                                <div class="category-icon">
                                    <i class="fas fa-sun"></i>
                                </div>
                                <div class="category-name">Breakfast</div>
                                <div class="category-status status-pending" id="breakfastStatus">Pending</div>
                            </div>
                            <div id="breakfastSuggestions">
                                <!-- Suggestions will be populated here -->
                            </div>
                        </div>
                        
                        <!-- Lunch -->
                        <div class="meal-category" id="lunchCategory">
                            <div class="category-header">
                                <div class="category-icon">
                                    <i class="fas fa-utensils"></i>
                                </div>
                                <div class="category-name">Lunch</div>
                                <div class="category-status status-pending" id="lunchStatus">Pending</div>
                            </div>
                            <div id="lunchSuggestions">
                                <!-- Suggestions will be populated here -->
                            </div>
                        </div>
                        
                        <!-- Snacks -->
                        <div class="meal-category" id="snacksCategory">
                            <div class="category-header">
                                <div class="category-icon">
                                    <i class="fas fa-cookie-bite"></i>
                                </div>
                                <div class="category-name">Snacks</div>
                                <div class="category-status status-pending" id="snacksStatus">Pending</div>
                            </div>
                            <div id="snacksSuggestions">
                                <!-- Suggestions will be populated here -->
                            </div>
                        </div>
                        
                        <!-- Dinner -->
                        <div class="meal-category" id="dinnerCategory">
                            <div class="category-header">
                                <div class="category-icon">
                                    <i class="fas fa-moon"></i>
                                </div>
                                <div class="category-name">Dinner</div>
                                <div class="category-status status-pending" id="dinnerStatus">Pending</div>
                            </div>
                            <div id="dinnerSuggestions">
                                <!-- Suggestions will be populated here -->
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Side Panel -->
                <div class="side-panel">
                    <!-- Meal Plan Summary -->
                    <div class="panel-card">
                        <h4 class="panel-title">Today's Meal Plan</h4>
                        <div class="meal-plan-summary" id="mealPlanSummary">
                            <div class="summary-item">
                                <span class="summary-meal">No meals selected yet</span>
                            </div>
                        </div>
                        <div class="total-summary">
                            <div class="total-calories" id="totalCalories">0 cal</div>
                            <div style="font-size: 0.9rem; color: var(--gray);">Total Calories</div>
                        </div>
                        
                        <div class="action-buttons" style="margin-top: 1rem; display: flex; gap: 0.5rem; flex-wrap: wrap;">
                            <button class="btn btn-outline" onclick="generateShoppingList()" style="font-size: 0.8rem; padding: 6px 12px;">
                                <i class="fas fa-shopping-cart"></i> Shopping List
                            </button>
                            <button class="btn btn-outline" onclick="showMealHistory()" style="font-size: 0.8rem; padding: 6px 12px;">
                                <i class="fas fa-history"></i> History
                            </button>
                        </div>
                    </div>
                    
                    <!-- Quick Actions -->
                    <div class="panel-card">
                        <h4 class="panel-title">Quick Actions</h4>
                        <div class="quick-actions">
                            <button class="btn btn-primary" onclick="addVoiceCommand()" style="width: 100%; margin-bottom: 0.5rem;">
                                <i class="fas fa-microphone"></i> Voice Command
                            </button>
                            <button class="btn btn-outline" onclick="setDietaryFilter('veg')" style="width: 100%; margin-bottom: 0.5rem;">
                                <i class="fas fa-leaf"></i> Show Only Veg
                            </button>
                            <button class="btn btn-outline" onclick="updateSpiceLevel('mild')" style="width: 100%;">
                                <i class="fas fa-fire"></i> Mild Spice Only
                            </button>
                        </div>
                    </div>
                    
                    <!-- Favorites -->
                    <div class="panel-card">
                        <h4 class="panel-title">❤️ Favorite Meals</h4>
                        <div id="favoritesList" style="max-height: 200px; overflow-y: auto;">
                            <div style="color: var(--gray); font-size: 0.9rem;">No favorites yet</div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    
    <!-- Floating AI Button -->
    <button class="floating-ai-btn" onclick="getAIRecommendation()">
        <i class="fas fa-robot"></i>
    </button>
    
    <script>
        let dailyGoals = {
            calories: { current: 650, target: 2000 },
            water: { current: 1.2, target: 3.0 },
            protein: { current: 45, target: 120 }
        };
        
        let selectedMeals = {};
        let regionalPreference = 'north';
        let dietaryFilter = 'all';
        let spiceLevel = 'medium';
        let cookingTime = 'all';
        let favoriteMeals = JSON.parse(localStorage.getItem('favoriteMeals') || '[]');
        let mealPlanCount = parseInt(localStorage.getItem('mealPlanCount_' + new Date().toDateString()) || '0');
        let mealPlanGenerated = mealPlanCount >= 3;
        let mealPlanCompleted = false;
        
        // All meal suggestions now come from backend API - no local database
        
        // Initialize the meal planner
        document.addEventListener('DOMContentLoaded', function() {
            loadUserGoals();
        });
        
        // Load user goals from API
        async function loadUserGoals() {
            try {
                const response = await fetch('/meal-planner/api/goals');
                const data = await response.json();
                
                if (data.success) {
                    dailyGoals = {
                        calories: { current: data.current.calories, target: data.goals.calories },
                        water: { current: data.current.water, target: data.goals.water },
                        protein: { current: data.current.protein, target: data.goals.protein }
                    };
                    
                    updateGoalsDisplay();
                    
                    // Load existing meals
                    data.meals.forEach(meal => {
                        selectedMeals[meal.category] = {
                            name: meal.name,
                            calories: meal.calories,
                            protein: meal.protein
                        };
                    });
                    
                    updateMealPlanSummary();
                }
            } catch (error) {
                console.error('Error loading goals:', error);
                updateGoalsDisplay(); // Use default values
            }
        }
        
        function startAIMealPlanning() {
            // Check if meal plan limit reached today
            if (mealPlanGenerated) {
                showToast('You can only generate 3 AI meal plans per day!', 'error');
                return;
            }
            
            showToast('Starting AI meal planning...', 'info');
            generateMealSuggestions();
            
            // Increment meal plan count for today
            mealPlanCount++;
            localStorage.setItem('mealPlanCount_' + new Date().toDateString(), mealPlanCount.toString());
            mealPlanGenerated = mealPlanCount >= 3;
        }
        
        function updateRegionalPreference() {
            regionalPreference = document.getElementById('regionalPreference').value;
            generateMealSuggestions();
            showToast(`Switched to ${regionalPreference.charAt(0).toUpperCase() + regionalPreference.slice(1)} Indian cuisine`, 'info');
        }
        
        async function generateMealSuggestions() {
            const categories = ['breakfast', 'lunch', 'snacks', 'dinner'];
            
            for (const category of categories) {
                if (!selectedMeals[category]) {
                    try {
                        const remainingCalories = dailyGoals.calories.target - dailyGoals.calories.current;
                        
                        const response = await fetch('/meal-planner/api/suggestions', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json'
                            },
                            body: JSON.stringify({
                                region: regionalPreference,
                                category: category,
                                remainingCalories: remainingCalories
                            })
                        });
                        
                        const data = await response.json();
                        
                        if (data.success) {
                            displayMealSuggestions(category, data.suggestions);
                        }
                    } catch (error) {
                        console.error('Error getting suggestions:', error);
                        showToast('Failed to load meal suggestions. Please try again.', 'error');
                    }
                }
            }
        }
        
        function displayMealSuggestions(category, meals) {
            const container = document.getElementById(category + 'Suggestions');
            container.innerHTML = '';
            
            meals.forEach(meal => {
                const suggestionCard = document.createElement('div');
                suggestionCard.className = 'meal-suggestion-card';
                suggestionCard.innerHTML = `
                    <div class="meal-info">
                        <div class="meal-details">
                            <h4>${meal.name}</h4>
                            <div class="meal-meta">
                                <span><i class="fas fa-fire"></i> ${meal.calories} cal</span>
                                <span><i class="fas fa-dumbbell"></i> ${meal.protein}g protein</span>
                                <span><i class="fas fa-clock"></i> ${Math.floor(Math.random() * 30) + 15} min</span>
                                <span><i class="fas fa-pepper-hot"></i> ${['Mild', 'Medium', 'Spicy'][Math.floor(Math.random() * 3)]}</span>
                            </div>
                            <p style="margin: 0.5rem 0 0 0; color: var(--gray); font-size: 0.9rem;">${meal.description}</p>
                            <div style="margin-top: 0.5rem;">
                                <strong>Ingredients:</strong> ${meal.ingredients.join(', ')}
                            </div>
                            <div class="nutrition-bar" style="margin-top: 0.5rem;">
                                <div style="display: flex; gap: 0.5rem; font-size: 0.8rem;">
                                    <span style="background: #ff6b6b; color: white; padding: 2px 6px; border-radius: 10px;">Carbs: ${Math.floor(meal.calories * 0.5)}g</span>
                                    <span style="background: #4ecdc4; color: white; padding: 2px 6px; border-radius: 10px;">Fat: ${Math.floor(meal.calories * 0.3)}g</span>
                                    <span style="background: #45b7d1; color: white; padding: 2px 6px; border-radius: 10px;">Protein: ${meal.protein}g</span>
                                </div>
                            </div>
                        </div>
                        <div class="meal-actions">
                            <button class="btn btn-favorite" onclick="toggleFavorite('${meal.name}')" id="fav-${meal.name.replace(/\s+/g, '')}">
                                <i class="far fa-heart"></i>
                            </button>
                            <button class="btn btn-accept" onclick="acceptMeal('${category}', '${meal.name}', ${meal.calories}, ${meal.protein})">
                                <i class="fas fa-check"></i> Accept
                            </button>
                            <button class="btn btn-reject" onclick="rejectMeal('${category}')">
                                <i class="fas fa-times"></i> Reject
                            </button>
                            <button class="btn btn-share" onclick="shareMeal('${meal.name}', '${meal.description}')">
                                <i class="fas fa-share-alt"></i>
                            </button>
                        </div>
                    </div>
                `;
                container.appendChild(suggestionCard);
            });
            
            // Add refresh button (always says Refresh)
            const refreshBtn = document.createElement('div');
            refreshBtn.style.textAlign = 'center';
            refreshBtn.style.marginTop = '1rem';
            refreshBtn.innerHTML = `
                <button class="btn btn-outline" onclick="refreshMeals('${category}')" style="background: var(--light); color: var(--primary); border: 1px solid var(--primary);">
                    <i class="fas fa-sync-alt"></i> Refresh
                </button>
            `;
            container.appendChild(refreshBtn);
        }
        
        async function refreshMeals(category) {
            try {
                const remainingCalories = dailyGoals.calories.target - dailyGoals.calories.current;
                
                const response = await fetch('/meal-planner/api/suggestions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        region: regionalPreference,
                        category: category,
                        remainingCalories: remainingCalories
                    })
                });
                
                const data = await response.json();
                
                if (data.success && data.suggestions.length > 0) {
                    // Shuffle and show different suggestions
                    const shuffled = data.suggestions.sort(() => 0.5 - Math.random());
                    displayMealSuggestions(category, shuffled);
                    showToast('Options refreshed!', 'success');
                } else {
                    showToast('No more options available', 'info');
                }
            } catch (error) {
                console.error('Error loading more meals:', error);
                showToast('Failed to refresh options. Please try again.', 'error');
            }
        }
        
        async function acceptMeal(category, name, calories, protein) {
            try {
                console.log('Saving meal:', { category, name, calories, protein });
                
                // Save to backend
                const response = await fetch('/meal-planner/meals', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        mealType: category,
                        name: name,
                        calories: calories,
                        protein: protein,
                        region: regionalPreference
                    })
                });
                
                console.log('Response status:', response.status);
                
                if (!response.ok) {
                    const errorText = await response.text();
                    console.error('Response error:', errorText);
                    showToast(`Failed to save meal: ${response.status}`, 'error');
                    return;
                }
                
                const result = await response.json();
                console.log('Response result:', result);
                
                if (result.success) {
                    selectedMeals[category] = { name, calories, protein };
                    
                    // Update daily goals
                    dailyGoals.calories.current += calories;
                    dailyGoals.protein.current += protein;
                    dailyGoals.water.current += 0.2;
                    
                    // Sync with dashboard
                    await syncWithDashboard();
                    
                    // Update displays
                    updateGoalsDisplay();
                    updateMealPlanSummary();
                    updateCategoryStatus(category);
                    
                    // Check if meal plan is complete
                    checkMealPlanCompletion();
                    
                    // Clear suggestions for this category
                    document.getElementById(category + 'Suggestions').innerHTML = `
                        <div style="text-align: center; padding: 1rem; color: var(--success);">
                            <i class="fas fa-check-circle"></i> ${name} added to your meal plan
                        </div>
                    `;
                    
                    showToast(`${name} added to ${category}!`, 'success');
                } else {
                    showToast(`Failed to save meal: ${result.error}`, 'error');
                }
            } catch (error) {
                console.error('Error saving meal:', error);
                showToast(`Error: ${error.message}`, 'error');
            }
        }
        
        async function rejectMeal(category) {
            try {
                const remainingCalories = dailyGoals.calories.target - dailyGoals.calories.current;
                
                const response = await fetch('/meal-planner/api/suggestions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        region: regionalPreference,
                        category: category,
                        remainingCalories: remainingCalories
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    // Shuffle and show different suggestions
                    const shuffled = data.suggestions.sort(() => 0.5 - Math.random());
                    displayMealSuggestions(category, shuffled);
                    showToast('New suggestions generated!', 'info');
                }
            } catch (error) {
                console.error('Error getting new suggestions:', error);
                showToast('Failed to get new suggestions. Please try again.', 'error');
            }
        }
        
        function updateGoalsDisplay() {
            // Update calories
            const caloriePercent = Math.min((dailyGoals.calories.current / dailyGoals.calories.target) * 100, 100);
            document.getElementById('calorieProgress').textContent = `${dailyGoals.calories.current} / ${dailyGoals.calories.target}`;
            document.getElementById('calorieBar').style.width = caloriePercent + '%';
            
            // Update water
            const waterPercent = Math.min((dailyGoals.water.current / dailyGoals.water.target) * 100, 100);
            document.getElementById('waterProgress').textContent = `${dailyGoals.water.current.toFixed(1)}L / ${dailyGoals.water.target}L`;
            document.getElementById('waterBar').style.width = waterPercent + '%';
            
            // Update protein
            const proteinPercent = Math.min((dailyGoals.protein.current / dailyGoals.protein.target) * 100, 100);
            document.getElementById('proteinProgress').textContent = `${dailyGoals.protein.current}g / ${dailyGoals.protein.target}g`;
            document.getElementById('proteinBar').style.width = proteinPercent + '%';
        }
        
        function updateMealPlanSummary() {
            const container = document.getElementById('mealPlanSummary');
            const totalCalories = document.getElementById('totalCalories');
            
            if (Object.keys(selectedMeals).length === 0) {
                container.innerHTML = '<div class="summary-item"><span class="summary-meal">No meals selected yet</span></div>';
                totalCalories.textContent = '0 cal';
                return;
            }
            
            let html = '';
            let total = 0;
            
            Object.keys(selectedMeals).forEach(category => {
                const meal = selectedMeals[category];
                html += `
                    <div class="summary-item">
                        <span class="summary-meal">${category.charAt(0).toUpperCase() + category.slice(1)}: ${meal.name}</span>
                        <span class="summary-calories">${meal.calories} cal</span>
                    </div>
                `;
                total += meal.calories;
            });
            
            container.innerHTML = html;
            totalCalories.textContent = total + ' cal';
        }
        
        function updateCategoryStatus(category) {
            const statusElement = document.getElementById(category + 'Status');
            statusElement.textContent = 'Completed';
            statusElement.className = 'category-status status-completed';
        }
        
        function getAIRecommendation() {
            const remainingCalories = dailyGoals.calories.target - dailyGoals.calories.current;
            const completedMeals = Object.keys(selectedMeals).length;
            
            let message = '';
            if (completedMeals === 0) {
                message = `Start with breakfast! I recommend light ${regionalPreference} Indian options.`;
            } else if (remainingCalories > 300) {
                message = `You have ${remainingCalories} calories left. Perfect for a balanced ${regionalPreference} dinner!`;
            } else {
                message = 'You\'re close to your calorie goal! Consider a light snack or increase your water intake.';
            }
            
            showToast(message, 'info');
        }
        
        function showToast(message, type) {
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            toast.textContent = message;
            document.body.appendChild(toast);
            
            setTimeout(() => toast.remove(), 3000);
        }
        
        // New Feature Functions
        function setDietaryFilter(filter) {
            dietaryFilter = filter;
            document.querySelectorAll('.filter-btn').forEach(btn => btn.classList.remove('active'));
            document.getElementById(filter + 'Filter').classList.add('active');
            generateMealSuggestions();
            showToast(`Filtered to ${filter} meals`, 'info');
        }
        
        function updateSpiceLevel() {
            spiceLevel = document.getElementById('spiceLevel').value;
            generateMealSuggestions();
            showToast(`Spice level set to ${spiceLevel}`, 'info');
        }
        
        function updateCookingTime() {
            cookingTime = document.getElementById('cookingTime').value;
            generateMealSuggestions();
            showToast(`Cooking time filter: ${cookingTime}`, 'info');
        }
        
        function toggleFavorite(mealName) {
            const btnId = 'fav-' + mealName.replace(/\s+/g, '');
            const btn = document.getElementById(btnId);
            const icon = btn.querySelector('i');
            
            if (favoriteMeals.includes(mealName)) {
                favoriteMeals = favoriteMeals.filter(m => m !== mealName);
                icon.className = 'far fa-heart';
                btn.classList.remove('active');
                showToast('Removed from favorites', 'info');
            } else {
                favoriteMeals.push(mealName);
                icon.className = 'fas fa-heart';
                btn.classList.add('active');
                showToast('Added to favorites!', 'success');
            }
            
            localStorage.setItem('favoriteMeals', JSON.stringify(favoriteMeals));
        }
        
        function shareMeal(mealName, description) {
            if (navigator.share) {
                navigator.share({
                    title: `Check out this meal: ${mealName}`,
                    text: description,
                    url: window.location.href
                });
            } else {
                navigator.clipboard.writeText(`${mealName}: ${description}`);
                showToast('Meal details copied to clipboard!', 'success');
            }
        }
        
        function generateShoppingList() {
            const ingredients = [];
            Object.values(selectedMeals).forEach(meal => {
                if (meal.ingredients) {
                    ingredients.push(...meal.ingredients);
                }
            });
            
            const uniqueIngredients = [...new Set(ingredients)];
            const list = uniqueIngredients.join('\n• ');
            
            navigator.clipboard.writeText('Shopping List:\n• ' + list);
            showToast('Shopping list copied to clipboard!', 'success');
        }
        
        function showMealHistory() {
            const history = JSON.parse(localStorage.getItem('mealHistory') || '[]');
            if (history.length === 0) {
                showToast('No meal history found', 'info');
                return;
            }
            
            const historyHtml = history.slice(-10).map(meal => 
                `<div class="history-item">${meal.name} - ${meal.date}</div>`
            ).join('');
            
            // Show in a modal or side panel
            showToast('Check console for meal history', 'info');
            console.log('Recent Meals:', history.slice(-10));
        }
        
        function addVoiceCommand() {
            if ('webkitSpeechRecognition' in window) {
                const recognition = new webkitSpeechRecognition();
                recognition.onresult = async function(event) {
                    const command = event.results[0][0].transcript.toLowerCase();
                    showToast(`Voice: "${command}"`, 'info');
                    
                    let category = null;
                    
                    // Detect meal type
                    if (command.includes('breakfast')) category = 'breakfast';
                    else if (command.includes('lunch')) category = 'lunch';
                    else if (command.includes('dinner')) category = 'dinner';
                    else if (command.includes('snack')) category = 'snacks';
                    
                    // Set filters based on voice command
                    if (command.includes('healthy') || command.includes('veg')) {
                        setDietaryFilter('veg');
                    }
                    if (command.includes('spicy')) {
                        document.getElementById('spiceLevel').value = 'spicy';
                        updateSpiceLevel();
                    }
                    if (command.includes('quick') || command.includes('fast')) {
                        document.getElementById('cookingTime').value = 'quick';
                        updateCookingTime();
                    }
                    
                    // Show suggestions for specific category or all
                    if (category) {
                        await generateSpecificMealSuggestions(category);
                        showToast(`Showing ${category} suggestions`, 'success');
                    } else {
                        await generateMealSuggestions();
                        showToast('Showing meal suggestions', 'success');
                    }
                };
                recognition.start();
            } else {
                showToast('Voice commands not supported', 'error');
            }
        }
        
        async function checkMealPlanCompletion() {
            const categories = ['breakfast', 'lunch', 'snacks', 'dinner'];
            const completedCategories = categories.filter(cat => selectedMeals[cat]);
            
            if (completedCategories.length === 4 && !mealPlanCompleted) {
                mealPlanCompleted = true;
                showToast('Meal plan completed! Sending email...', 'success');
                await sendMealPlanEmail();
            }
        }
        
        async function sendMealPlanEmail() {
            try {
                const response = await fetch('/meal-planner/send-email', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        meals: selectedMeals,
                        totalCalories: Object.values(selectedMeals).reduce((sum, meal) => sum + meal.calories, 0),
                        totalProtein: Object.values(selectedMeals).reduce((sum, meal) => sum + meal.protein, 0),
                        region: regionalPreference,
                        date: new Date().toDateString()
                    })
                });
                
                const result = await response.json();
                
                if (result.success) {
                    showToast('Meal plan sent to your email!', 'success');
                } else {
                    showToast('Failed to send email', 'error');
                }
            } catch (error) {
                console.error('Error sending email:', error);
                showToast('Email sending failed', 'error');
            }
        }
        
        async function syncWithDashboard() {
            try {
                const response = await fetch('/api/update-goals', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        calories: dailyGoals.calories.current,
                        protein: dailyGoals.protein.current,
                        water: dailyGoals.water.current
                    })
                });
                
                if (response.ok) {
                    console.log('Dashboard synced successfully');
                }
            } catch (error) {
                console.error('Dashboard sync failed:', error);
            }
        }
        
        async function generateSpecificMealSuggestions(category) {
            try {
                const remainingCalories = dailyGoals.calories.target - dailyGoals.calories.current;
                
                const response = await fetch('/meal-planner/api/suggestions', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({
                        region: regionalPreference,
                        category: category,
                        remainingCalories: remainingCalories,
                        dietaryFilter: dietaryFilter,
                        spiceLevel: spiceLevel,
                        cookingTime: cookingTime
                    })
                });
                
                const data = await response.json();
                
                if (data.success) {
                    displayMealSuggestions(category, data.suggestions);
                }
            } catch (error) {
                console.error('Error getting voice suggestions:', error);
                showToast('Failed to get suggestions', 'error');
            }
        }
    </script>
</body>
</html>
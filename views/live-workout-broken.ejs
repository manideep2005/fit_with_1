        window.incrementReps = function() {
            const repEl = document.getElementById('repCount');
            const current = parseInt(repEl.textContent) || 0;
            const newCount = current + 1;
            repEl.textContent = newCount;
            
            if (newCount % 10 === 0) {
                showToast(`Great job! ${newCount} reps completed! 🔥`, 'success');
            }
            addChatMessage(`💪 Rep count: ${newCount}`, 'system');
        };
        
        window.resetReps = function() {
            document.getElementById('repCount').textContent = '0';
            showToast('Rep counter reset', 'info');
            addChatMessage('🔄 Reps reset to 0', 'system');
        };
        
        window.startWorkoutTimer = function() {
            if (timerInterval) {
                showToast('Timer is already running!', 'warning');
                return;
            }
            
            timerInterval = setInterval(() => {
                workoutTimer++;
                const minutes = Math.floor(workoutTimer / 60);
                const seconds = workoutTimer % 60;
                document.getElementById('workoutTimer').textContent = 
                    `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }, 1000);
            
            showToast('Workout timer started! 💪', 'success');
            addChatMessage('⏱️ Workout timer started!', 'system');
        };
        
        window.stopWorkoutTimer = function() {
            if (timerInterval) {
                clearInterval(timerInterval);
                timerInterval = null;
                const minutes = Math.floor(workoutTimer / 60);
                const seconds = workoutTimer % 60;
                showToast(`Timer stopped at ${minutes}:${seconds.toString().padStart(2, '0')}`, 'info');
                addChatMessage(`⏱️ Timer stopped at ${minutes}:${seconds.toString().padStart(2, '0')}`, 'system');
            } else {
                showToast('Timer is not running!', 'warning');
            }
        };
        

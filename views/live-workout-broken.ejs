        async function inviteFriend(friendId, friendName, friendEmail) {
            console.log('Invite friend clicked:', { friendId, friendName, friendEmail });
            
            // Get the button that was clicked and disable it
            const btn = event.target;
            const originalText = btn.textContent;
            btn.disabled = true;
            btn.textContent = 'Sending...';
            btn.style.background = '#ffc107';
            
            try {
                if (!currentSessionId) {
                    throw new Error('No active session');
                }
                
                const inviteUrl = `${window.location.origin}/live-workout?sessionId=${currentSessionId}`;
                console.log('Sending invitation with data:', {
                    friendId, friendEmail, sessionId: currentSessionId, inviteUrl, friendName
                });
                
                const response = await fetch('/api/live-workout/invite', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        friendId: friendId,
                        friendEmail: friendEmail,
                        sessionId: currentSessionId,
                        inviteUrl: inviteUrl,
                        friendName: friendName
                    })
                });
                
                const result = await response.json();
                console.log('Invitation response:', result);
                
                if (result.success) {
                    showSuccess(`Invitation sent to ${friendName}!`);
                    addChatMessage(`Invitation sent to ${friendName}`, 'system');
                    btn.textContent = 'Sent!';
                    btn.style.background = 'var(--success)';
                } else {
                    throw new Error(result.error || 'Failed to send invitation');
                }
            } catch (error) {
                console.error('Error inviting friend:', error);
                showError(error.message || 'Failed to send invitation');
                btn.disabled = false;
                btn.textContent = originalText;
                btn.style.background = 'var(--success)';
            }
        }

        function sendMessage() {
            const input = document.getElementById('chatInput');
            const message = input.value.trim();
            
            if (message && currentSessionId) {
                socket.emit('live-workout-chat', {
                    sessionId: currentSessionId,
                    message: message
                });
                input.value = '';
            }
        }

        function leaveSession() {
            if (currentSessionId) {
                socket.emit('leave-live-workout', { sessionId: currentSessionId });
                window.location.reload();
            }
        }

        // Socket events
        socket.on('live-workout-created', (data) => {
            showSuccess('Session created!');
            setTimeout(() => switchToWorkout(data.session), 1000);
        });

        socket.on('live-workout-joined', (data) => {
            showSuccess('Joined session!');
            setTimeout(() => switchToWorkout(data.session), 1000);
        });

        socket.on('live-workout-error', (data) => {
            showError(data.message);
        });

        socket.on('user-joined-live-workout', (data) => {
            addParticipant(data.userId, data.userName);
            addChatMessage(`${data.userName} joined`, 'system');
            document.getElementById('participantCount').textContent = data.participantCount;
        });

        socket.on('user-left-live-workout', (data) => {
            removeParticipant(data.userId);
            addChatMessage(`${data.userName} left`, 'system');
        });

        socket.on('live-workout-chat', (data) => {
            addChatMessage(data.message, data.type, data.userName);
        });

        function addParticipant(userId, userName) {
            const participantsList = document.getElementById('participantsList');
            const participantDiv = document.createElement('div');
            participantDiv.className = 'participant-item';
            participantDiv.id = `participant-${userId}`;
            participantDiv.innerHTML = `
                <div class="participant-avatar">${userName.charAt(0)}</div>
                <div>
                    <div>${userName}</div>
                    <small style="color: var(--success);">● Connected</small>
                </div>
            `;
            participantsList.appendChild(participantDiv);
        }

        function removeParticipant(userId) {
            const element = document.getElementById(`participant-${userId}`);
            if (element) element.remove();
        }

        function addChatMessage(message, type = 'user', userName = '') {
            const chatMessages = document.getElementById('chatMessages');
            if (!chatMessages) {
                console.log('Chat message:', message);
                return;
            }
            
            const messageDiv = document.createElement('div');
            messageDiv.className = 'chat-message';
            messageDiv.style.cssText = 'background: rgba(255,255,255,0.1); padding: 8px 12px; border-radius: 8px; margin-bottom: 8px; font-size: 0.9rem; color: white;';
            
            if (type === 'system') {
                messageDiv.style.fontStyle = 'italic';
                messageDiv.style.opacity = '0.8';
                messageDiv.style.background = 'rgba(108, 99, 255, 0.2)';
                messageDiv.style.textAlign = 'center';
                messageDiv.textContent = message;
            } else {
                messageDiv.innerHTML = `<strong>${userName}:</strong> ${message}`;
            }
            
            chatMessages.appendChild(messageDiv);
            chatMessages.scrollTop = chatMessages.scrollHeight;
        }
        
        // Make addChatMessage globally accessible
        window.addChatMessage = addChatMessage;
        
        // Toast notification system
        function showToast(message, type = 'info') {
            const toast = document.createElement('div');
            toast.className = `toast toast-${type}`;
            toast.textContent = message;
            toast.style.cssText = `
                position: fixed;
                top: 20px;
                right: 20px;
                padding: 16px 24px;
                border-radius: 12px;
                color: white;
                font-weight: 600;
                z-index: 10000;
                transform: translateX(100%);
                transition: transform 0.3s ease;
                box-shadow: 0 8px 32px rgba(0,0,0,0.3);
                backdrop-filter: blur(10px);
                min-width: 300px;
                max-width: 400px;
            `;
            
            // Set background color based on type
            const colors = {
                success: 'linear-gradient(135deg, #28a745, #20c997)',
                error: 'linear-gradient(135deg, #dc3545, #e74c3c)',
                warning: 'linear-gradient(135deg, #ffc107, #f39c12)',
                info: 'linear-gradient(135deg, #6c63ff, #4d44db)'
            };
            toast.style.background = colors[type] || colors.info;
            
            document.body.appendChild(toast);
            
            // Animate in
            setTimeout(() => {
                toast.style.transform = 'translateX(0)';
            }, 100);
            
            // Auto remove
            setTimeout(() => {
                toast.style.transform = 'translateX(100%)';
                setTimeout(() => {
                    if (toast.parentNode) {
                        toast.parentNode.removeChild(toast);
                    }
                }, 300);
            }, 3000);
        }
        
        // Make toast function globally accessible
        window.showToast = showToast;

        // Chat enter key
        document.getElementById('chatInput').addEventListener('keypress', (e) => {
            if (e.key === 'Enter') sendMessage();
        });

        // Utility functions
        function showError(message) {
            const errorDiv = document.getElementById('errorMessage');
            errorDiv.textContent = message;
            errorDiv.style.display = 'block';
            setTimeout(() => errorDiv.style.display = 'none', 5000);
        }

        function showSuccess(message) {
            const successDiv = document.getElementById('successMessage');
            successDiv.textContent = message;
            successDiv.style.display = 'block';
            setTimeout(() => successDiv.style.display = 'none', 3000);
        }

        // Enhanced Workout Features Functions
        function startWorkoutTimer() {
            if (timerInterval) clearInterval(timerInterval);
            workoutTimer = 0;
            isWorkoutActive = true;
            
            timerInterval = setInterval(() => {
                workoutTimer++;
                const minutes = Math.floor(workoutTimer / 60);
                const seconds = workoutTimer % 60;
                updateTimerDisplay(`${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`);
            }, 1000);
            
            addChatMessage('⏱️ Workout timer started!', 'system');
        }
        
        function stopWorkoutTimer() {
            if (timerInterval) {
                clearInterval(timerInterval);
                timerInterval = null;
            }
            isWorkoutActive = false;
            addChatMessage(`⏱️ Workout completed! Total time: ${Math.floor(workoutTimer / 60)}:${(workoutTimer % 60).toString().padStart(2, '0')}`, 'system');
        }
        
        function updateTimerDisplay(time) {
            const timerEl = document.getElementById('workoutTimer');
            if (timerEl) timerEl.textContent = time;
        }
        
        function incrementReps() {
            repCount++;
            const repCountEl = document.getElementById('repCount');
            if (repCountEl) repCountEl.textContent = repCount;
            
            if (leaderboardData.length > 0) {
                leaderboardData[0].reps = repCount;
            }
            
            addChatMessage(`💪 Rep count: ${repCount}`, 'system');
        }
        
        function resetReps() {
            repCount = 0;
            const repCountEl = document.getElementById('repCount');
            if (repCountEl) repCountEl.textContent = repCount;
            
            if (leaderboardData.length > 0) {
                leaderboardData[0].reps = 0;
            }
        }
        
        function toggleMusic() {
            musicPlaying = !musicPlaying;
            
            if (musicPlaying) {
                addChatMessage(`🎵 Now playing: ${musicTracks[currentTrackIndex]}`, 'system');
            } else {
                addChatMessage('🎵 Music paused', 'system');
            }
        }
        
        function nextTrack() {
            currentTrackIndex = (currentTrackIndex + 1) % musicTracks.length;
            addChatMessage(`🎵 Next track: ${musicTracks[currentTrackIndex]}`, 'system');
        }
        
        function previousTrack() {
            currentTrackIndex = currentTrackIndex === 0 ? musicTracks.length - 1 : currentTrackIndex - 1;
            addChatMessage(`🎵 Previous track: ${musicTracks[currentTrackIndex]}`, 'system');
        }
        
        function sendReaction(emoji) {
            addChatMessage(`${emoji} reaction sent!`, 'system');
            
            if (socket && currentSessionId) {
                socket.emit('workout-reaction', {
                    sessionId: currentSessionId,
                    reaction: emoji
                });
            }
        }
        
        function nextExercise() {
            if (currentExerciseIndex < workoutExercises.length - 1) {
                workoutExercises[currentExerciseIndex].completed = true;
                currentExerciseIndex++;
                addChatMessage(`Next exercise: ${workoutExercises[currentExerciseIndex].name}`, 'system');
            } else {
                stopWorkoutTimer();
                addChatMessage('🎉 All exercises completed! Great job!', 'system');
            }
        }
        
        // Make enhanced functions globally accessible
        window.startWorkoutTimer = startWorkoutTimer;
        window.stopWorkoutTimer = stopWorkoutTimer;
        window.incrementReps = incrementReps;
        window.resetReps = resetReps;
        window.toggleMusic = toggleMusic;
        window.nextTrack = nextTrack;
        window.previousTrack = previousTrack;
        window.sendReaction = sendReaction;
        window.nextExercise = nextExercise;
        
        // Check URL for session ID
        const urlParams = new URLSearchParams(window.location.search);
        const urlSessionId = urlParams.get('sessionId');
        if (urlSessionId) {
            document.getElementById('sessionId').value = urlSessionId;
        }
    </script>
</body>
</html>
        function generateSessionId() {
            const chars = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789';
            let result = '';
            for (let i = 0; i < 9; i++) {
                if (i === 3 || i === 6) result += '-';
                else result += chars.charAt(Math.floor(Math.random() * chars.length));
            }
            return result;

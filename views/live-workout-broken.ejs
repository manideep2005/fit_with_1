<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Live Workout - Fit-With-AI</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
    <style>
        :root {
            --primary: #6C63FF;
            --success: #28a745;
            --danger: #dc3545;
            --warning: #ffc107;
        }

        * { margin: 0; padding: 0; box-sizing: border-box; }
        body { 
            font-family: 'Poppins', sans-serif; 
            background: linear-gradient(135deg, var(--primary), #4D44DB);
            min-height: 100vh;
            color: white;
        }

        /* Join Screen */
        .join-screen {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin-left: 250px;
        }

        .join-container {
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 40px;
            max-width: 500px;
            width: 90%;
            text-align: center;
            box-shadow: 0 20px 40px rgba(0,0,0,0.2);
        }

        .session-input {
            background: rgba(255,255,255,0.2);
            border: 2px solid rgba(255,255,255,0.3);
            border-radius: 15px;
            padding: 15px 20px;
            font-size: 1.2rem;
            color: white;
            width: 100%;
            text-align: center;
            margin-bottom: 20px;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .session-input::placeholder {
            color: rgba(255,255,255,0.7);
            text-transform: none;
            letter-spacing: normal;
        }

        .btn {
            background: var(--success);
            color: white;
            border: none;
            padding: 15px 30px;
            border-radius: 25px;
            font-size: 1.1rem;
            font-weight: 600;
            cursor: pointer;
            width: 100%;
            margin-bottom: 20px;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        .btn:hover { transform: translateY(-2px); }
        .btn-secondary { background: rgba(255,255,255,0.2); }

        /* Workout Screen */
        .workout-screen {
            display: none;
            height: 100vh;
            flex-direction: column;
            background: #000;
            margin-left: 250px;
            position: relative;
        }
        
        /* Enhanced UI Layout */
        .workout-timer {
            position: absolute;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            background: rgba(0,0,0,0.9);
            padding: 15px 30px;
            border-radius: 25px;
            font-size: 2.5rem;
            font-weight: 700;
            color: #00ff00;
            font-family: 'Courier New', monospace;
            z-index: 100;
            border: 2px solid rgba(0,255,0,0.3);
            box-shadow: 0 0 20px rgba(0,255,0,0.3);
        }
        
        .rep-counter {
            position: absolute;
            top: 50%;
            right: 30px;
            transform: translateY(-50%);
            background: rgba(0,0,0,0.9);
            padding: 30px;
            border-radius: 20px;
            text-align: center;
            cursor: pointer;
            z-index: 100;
            border: 2px solid rgba(255,107,107,0.3);
            box-shadow: 0 0 20px rgba(255,107,107,0.3);
            transition: all 0.3s ease;
        }
        
        .rep-counter:hover {
            transform: translateY(-50%) scale(1.05);
            box-shadow: 0 0 30px rgba(255,107,107,0.5);
        }
        
        .rep-count {
            font-size: 4rem;
            font-weight: 900;
            color: #ff6b6b;
            margin-bottom: 10px;
            text-shadow: 0 0 20px rgba(255,107,107,0.5);
        }
        
        .music-controls {
            position: absolute;
            top: 20px;
            left: 30px;
            background: rgba(0,0,0,0.9);
            padding: 15px 20px;
            border-radius: 15px;
            display: flex;
            align-items: center;
            gap: 15px;
            z-index: 100;
            border: 1px solid rgba(255,255,255,0.2);
            backdrop-filter: blur(10px);
        }
        
        .music-btn {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            border: none;
            background: rgba(255,255,255,0.2);
            color: white;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }
        
        .music-btn:hover {
            background: var(--primary);
            transform: scale(1.1);
        }
        
        .music-btn.playing {
            background: var(--success);
            animation: pulse 2s infinite;
        }
        
        .workout-reactions {
            position: absolute;
            bottom: 200px;
            left: 30px;
            display: flex;
            flex-direction: column;
            gap: 12px;
            z-index: 100;
        }
        
        .reaction-btn {
            width: 55px;
            height: 55px;
            border-radius: 50%;
            border: none;
            background: rgba(0,0,0,0.8);
            font-size: 1.8rem;
            cursor: pointer;
            transition: all 0.3s ease;
            backdrop-filter: blur(10px);
            border: 2px solid rgba(255,255,255,0.2);
        }
        
        .reaction-btn:hover {
            transform: scale(1.2);
            background: rgba(255,255,255,0.2);
            box-shadow: 0 0 20px rgba(255,255,255,0.3);
        }
        
        @keyframes pulse {
            0%, 100% { opacity: 1; }
            50% { opacity: 0.7; }
        }

        .workout-header {
            background: rgba(0,0,0,0.8);
            padding: 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .workout-main {
            flex: 1;
            display: flex;
            position: relative;
        }

        .video-area {
            flex: 1;
            background: #111;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
        }

        .workout-video {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        .video-controls {
            position: absolute;
            bottom: 20px;
            left: 50%;
            transform: translateX(-50%);
            display: flex;
            gap: 15px;
            background: rgba(0,0,0,0.7);
            padding: 15px;
            border-radius: 25px;
        }

        .control-btn {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            border: none;
            background: rgba(255,255,255,0.2);
            color: white;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

        .control-btn:hover { background: rgba(255,255,255,0.3); transform: scale(1.1); }
        .control-btn.active { background: var(--success); }
        .control-btn.muted { background: var(--danger); }

        .participants-panel {
            width: 300px;
            background: rgba(0,0,0,0.9);
            padding: 20px;
            overflow-y: auto;
        }

        .participant-item {
            display: flex;
            align-items: center;
            gap: 15px;
            padding: 10px;
            margin-bottom: 10px;
            background: rgba(255,255,255,0.1);
            border-radius: 10px;
        }

        .participant-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--primary);
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        .chat-area {
            position: absolute;
            top: 100px;
            right: 20px;
            width: 300px;
            height: 400px;
            background: rgba(0,0,0,0.8);
            border-radius: 15px;
            padding: 15px;
            display: flex;
            flex-direction: column;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            margin-bottom: 15px;
        }

        .chat-message {
            background: rgba(255,255,255,0.1);
            padding: 8px 12px;
            border-radius: 8px;
            margin-bottom: 8px;
            font-size: 0.9rem;
        }

        .chat-input {
            display: flex;
            gap: 10px;
        }

        .chat-input input {
            flex: 1;
            padding: 8px;
            border: none;
            border-radius: 5px;
            background: rgba(255,255,255,0.2);
            color: white;
        }

        .chat-input button {
            background: var(--primary);
            color: white;
            border: none;
            padding: 8px 12px;
            border-radius: 5px;
            cursor: pointer;
        }

        /* Modal */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.8);
            z-index: 2000;
            align-items: center;
            justify-content: center;
        }

        .modal-content {
            background: white;
            border-radius: 15px;
            padding: 30px;
            max-width: 500px;
            width: 90%;
            color: #333;
        }

        .friend-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 10px;
            border: 1px solid #eee;
            border-radius: 8px;
            margin-bottom: 8px;
        }

        .friend-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: var(--primary);
            color: white;
            display: flex;
            align-items: center;
            justify-content: center;
            font-weight: 600;
        }

        .invite-btn {
            background: var(--success);
            color: white;
            border: none;
            padding: 8px 16px;
            border-radius: 6px;
            cursor: pointer;
        }

        .message { padding: 15px; border-radius: 10px; margin-bottom: 20px; display: none; }
        .error { background: rgba(220, 53, 69, 0.2); border: 1px solid rgba(220, 53, 69, 0.5); color: #ff6b6b; }
        .success { background: rgba(40, 167, 69, 0.2); border: 1px solid rgba(40, 167, 69, 0.5); color: #51cf66; }
    </style>
</head>
<body>
    <!-- Sidebar Navigation -->
    <div class="sidebar" style="position: fixed; top: 0; left: 0; width: 250px; height: 100vh; background: white; box-shadow: 2px 0 10px rgba(0,0,0,0.1); padding: 2rem 1rem; z-index: 100; overflow-y: auto;">
        <div class="sidebar-header" style="display: flex; align-items: center; margin-bottom: 2rem; padding: 0 1rem;">
            <img src="https://ui-avatars.com/api/?name=User&background=6C63FF&color=fff" alt="User Avatar" style="width: 40px; height: 40px; border-radius: 50%; margin-right: 10px;">
            <div>
                <h3 style="font-weight: 600; margin: 0; color: #343A40;">User</h3>
                <span style="font-size: 0.8rem; color: #6C63FF; background: rgba(108, 99, 255, 0.1); padding: 2px 8px; border-radius: 20px; margin-top: 5px;">Premium Plan</span>
            </div>
        </div>
        
        <ul style="list-style: none; padding: 0; margin: 0;">
            <li style="margin-bottom: 5px;"><a href="/dashboard" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-home" style="margin-right: 10px; font-size: 1.2rem;"></i> Dashboard</a></li>
            <li style="margin-bottom: 5px;"><a href="/workouts" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-dumbbell" style="margin-right: 10px; font-size: 1.2rem;"></i> Workouts</a></li>
            <li style="margin-bottom: 5px;"><a href="/live-workout" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C63FF; background: rgba(108, 99, 255, 0.1); text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-broadcast-tower" style="margin-right: 10px; font-size: 1.2rem;"></i> Live Workouts</a></li>
            <li style="margin-bottom: 5px;"><a href="/progress" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-chart-line" style="margin-right: 10px; font-size: 1.2rem;"></i> Progress</a></li>
            <li style="margin-bottom: 5px;"><a href="/analytics" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-chart-bar" style="margin-right: 10px; font-size: 1.2rem;"></i> Analytics</a></li>
            <li style="margin-bottom: 5px;"><a href="/nutrition" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-utensils" style="margin-right: 10px; font-size: 1.2rem;"></i> Nutrition</a></li>
            <li style="margin-bottom: 5px;"><a href="/nutriscan" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-qrcode" style="margin-right: 10px; font-size: 1.2rem;"></i> NutriScan</a></li>
            <li style="margin-bottom: 5px;"><a href="/meal-planner" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-calendar-check" style="margin-right: 10px; font-size: 1.2rem;"></i> Meal Planner</a></li>
            <li style="margin-bottom: 5px;"><a href="/challenges" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-trophy" style="margin-right: 10px; font-size: 1.2rem;"></i> Challenges</a></li>
            <li style="margin-bottom: 5px;"><a href="/health" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-heartbeat" style="margin-right: 10px; font-size: 1.2rem;"></i> Health Metrics</a></li>
            <li style="margin-bottom: 5px;"><a href="/biometrics" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-chart-bar" style="margin-right: 10px; font-size: 1.2rem;"></i> Biometrics</a></li>
            <li style="margin-bottom: 5px;"><a href="/schedule" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-calendar-alt" style="margin-right: 10px; font-size: 1.2rem;"></i> Schedule</a></li>
            <li style="margin-bottom: 5px;"><a href="/community" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-users" style="margin-right: 10px; font-size: 1.2rem;"></i> Community</a></li>
            <li style="margin-bottom: 5px;"><a href="/chat" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-comments" style="margin-right: 10px; font-size: 1.2rem;"></i> Chat</a></li>
            <li style="margin-bottom: 5px;"><a href="/ai-coach" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-robot" style="margin-right: 10px; font-size: 1.2rem;"></i> AI Coach</a></li>
            <li style="margin-bottom: 5px;"><a href="/settings" style="display: flex; align-items: center; padding: 12px 1rem; color: #6C757D; text-decoration: none; border-radius: 8px; transition: all 0.3s ease;"><i class="fas fa-cog" style="margin-right: 10px; font-size: 1.2rem;"></i> Settings</a></li>
        </ul>
        
        <div style="margin-top: 2rem; padding-top: 1rem; border-top: 1px solid #E9ECEF;">
            <a href="/logout" style="display: flex; align-items: center; padding: 12px 1rem; color: #DC3545; text-decoration: none; border-radius: 8px; transition: all 0.3s ease; font-weight: 500;">
                <i class="fas fa-sign-out-alt" style="margin-right: 10px; font-size: 1.2rem;"></i> Logout
            </a>
        </div>
    </div>

    <!-- Join Screen -->
    <div id="joinScreen" class="join-screen" style="margin-left: 250px;">
        <div class="join-container">
            <div style="font-size: 3rem; margin-bottom: 20px;">🏋️‍♂️</div>
            <h1 style="font-size: 2rem; margin-bottom: 10px;">Live Workout</h1>
            <p style="opacity: 0.9; margin-bottom: 30px;">Join a session or create your own</p>

            <div id="errorMessage" class="message error"></div>
            <div id="successMessage" class="message success"></div>

            <input type="text" id="sessionId" class="session-input" placeholder="Enter Session ID (e.g., ABC-DEF-GHI)" maxlength="11">
            <button type="button" class="btn" onclick="joinSession()">
                <i class="fas fa-video"></i> Join Workout
            </button>

            <button type="button" class="btn btn-secondary" onclick="createSession()">
                <i class="fas fa-plus"></i> Create New Session
            </button>
            
            <button type="button" class="btn" onclick="testButtons()" style="background: orange; margin-top: 10px;">
                <i class="fas fa-bug"></i> Test Buttons
            </button>
        </div>
    </div>

    <!-- Workout Screen -->
    <div id="workoutScreen" class="workout-screen">
        <!-- Enhanced Features -->
        <div id="workoutTimer" style="position: absolute; top: 20px; left: 50%; transform: translateX(-50%); background: rgba(0,0,0,0.8); padding: 15px 30px; border-radius: 25px; font-size: 2rem; font-weight: 700; color: #00ff00; font-family: 'Courier New', monospace; z-index: 100;">00:00</div>
        
        <div id="repCounter" style="position: absolute; top: 50%; right: 20px; transform: translateY(-50%); background: rgba(0,0,0,0.8); padding: 30px; border-radius: 20px; text-align: center; cursor: pointer; z-index: 100;" onclick="incrementReps()" title="Click to add reps">
            <div style="font-size: 4rem; font-weight: 900; color: #ff6b6b; margin-bottom: 10px;" id="repCount">0</div>
            <div style="color: white; font-size: 1rem;">Reps (Click to add)</div>
            <button onclick="event.stopPropagation(); resetReps()" style="background: var(--danger); color: white; border: none; padding: 5px 10px; border-radius: 5px; margin-top: 10px; cursor: pointer;">Reset</button>
        </div>
        
        <div id="musicControls" style="position: absolute; top: 20px; left: 20px; background: rgba(0,0,0,0.8); padding: 15px 20px; border-radius: 15px; display: flex; align-items: center; gap: 15px; z-index: 100;">
            <button onclick="previousTrack()" style="width: 40px; height: 40px; border-radius: 50%; border: none; background: rgba(255,255,255,0.2); color: white; cursor: pointer;"><i class="fas fa-step-backward"></i></button>
            <button onclick="toggleMusic()" style="width: 40px; height: 40px; border-radius: 50%; border: none; background: rgba(255,255,255,0.2); color: white; cursor: pointer;"><i class="fas fa-play"></i></button>
            <button onclick="nextTrack()" style="width: 40px; height: 40px; border-radius: 50%; border: none; background: rgba(255,255,255,0.2); color: white; cursor: pointer;"><i class="fas fa-step-forward"></i></button>
            <span style="color: white; font-size: 0.9rem; margin-left: 10px;">No music</span>
        </div>
        
        <div id="workoutReactions" class="workout-reactions">
            <button onclick="sendReaction('💪')" class="reaction-btn" title="Strong">💪</button>
            <button onclick="sendReaction('🔥')" class="reaction-btn" title="Fire">🔥</button>
            <button onclick="sendReaction('👏')" class="reaction-btn" title="Clap">👏</button>
            <button onclick="sendReaction('😅')" class="reaction-btn" title="Tired">😅</button>
            <button onclick="sendReaction('⚡')" class="reaction-btn" title="Energy">⚡</button>
        </div>
        
        <div id="exerciseQueue" style="position: absolute; top: 100px; left: 30px; background: rgba(0,0,0,0.9); padding: 20px; border-radius: 15px; width: 280px; z-index: 50; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(10px);">
            <h4 style="margin: 0 0 15px 0; color: white;">🏋️ Exercise Queue</h4>
            <div class="exercise-item active">
                <div>
                    <div style="font-weight: 600; color: white;">Push-ups</div>
                    <div style="font-size: 0.8rem; color: rgba(255,255,255,0.7);">60s • 20 reps</div>
                </div>
                <div style="color: white; font-size: 1.2rem;">▶️</div>
            </div>
            <div class="exercise-item">
                <div>
                    <div style="font-weight: 600; color: white;">Squats</div>
                    <div style="font-size: 0.8rem; color: rgba(255,255,255,0.7);">60s • 25 reps</div>
                </div>
                <div style="color: white; font-size: 1.2rem;">⏸️</div>
            </div>
            <div class="exercise-item">
                <div>
                    <div style="font-weight: 600; color: white;">Plank</div>
                    <div style="font-size: 0.8rem; color: rgba(255,255,255,0.7);">30s • Hold</div>
                </div>
                <div style="color: white; font-size: 1.2rem;">⏸️</div>
            </div>
        </div>
        <div class="workout-header">
            <div>
                <i class="fas fa-dumbbell"></i>
                <span>Workout Session</span>
                <small id="sessionIdDisplay"></small>
            </div>
            <div>
                Participants: <span id="participantCount">1</span>
                <button onclick="leaveSession()" style="background: var(--danger); color: white; border: none; padding: 8px 16px; border-radius: 5px; cursor: pointer; margin-left: 15px;">
                    Leave
                </button>
            </div>
        </div>

        <div class="workout-main">
            <div class="video-area">
                <video id="localVideo" class="workout-video" autoplay muted playsinline></video>
                
                <div class="video-controls">
                    <button class="control-btn" id="cameraBtn" onclick="toggleCamera()">
                        <i class="fas fa-video"></i>
                    </button>
                    <button class="control-btn" id="micBtn" onclick="toggleMic()">
                        <i class="fas fa-microphone"></i>
                    </button>
                    <button class="control-btn" onclick="shareScreen()">
                        <i class="fas fa-desktop"></i>
                    </button>
                    <button class="control-btn" id="inviteBtn" onclick="showInviteModal()">
                        <i class="fas fa-user-plus"></i>
                    </button>
                    <button class="control-btn" onclick="copyLink()">
                        <i class="fas fa-link"></i>
                    </button>
                    <button class="control-btn" onclick="startWorkoutTimer()" style="background: var(--success);" title="Start Timer">
                        <i class="fas fa-play"></i>
                    </button>
                    <button class="control-btn" onclick="stopWorkoutTimer()" title="Stop Timer">
                        <i class="fas fa-stop"></i>
                    </button>
                    <button class="control-btn" onclick="nextExercise()" title="Next Exercise">
                        <i class="fas fa-forward"></i>
                    </button>
                </div>
            </div>

